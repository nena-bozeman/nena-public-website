{
  "name": "nena-website",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "check": "astro check",
    "inventory:legacy": "node scripts/build-legacy-inventory.mjs",
    "inventory:legacy:quick": "node scripts/build-legacy-inventory.mjs --no-crawl-assets",
    "redirects:legacy": "node scripts/build-cloudflare-redirects.mjs",
    "check:internal-links": "node scripts/check-internal-links.mjs",
    "legacy-mysql:up": "cd data/docker/legacy-mysql && docker compose up -d",
    "legacy-mysql:stop": "cd data/docker/legacy-mysql && docker compose stop",
    "legacy-mysql:down": "cd data/docker/legacy-mysql && docker compose down",
    "legacy-mysql:down-v": "cd data/docker/legacy-mysql && docker compose down -v",
    "content:development-from-legacy": "node scripts/export-development-from-legacy.mjs",
    "content:news-from-blog": "node scripts/backfill-news-from-blog.mjs",
    "geocode:businesses": "node scripts/geocode-business-addresses.mjs",
    "images:business-heroes": "node scripts/fetch-business-hero-images.mjs",
    "build:cf": "ASTRO_BASE_PATH=/ npm run build",
    "check:internal-links:cf": "ASTRO_BASE_PATH=/ npm run build && ASTRO_BASE_PATH=/ npm run check:internal-links"
  },
  "dependencies": {
    "@astrojs/tailwind": "^5.1.0",
    "astro": "^5.15.8",
    "tailwindcss": "^3.4.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@tailwindcss/typography": "^0.5.19",
    "js-yaml": "^4.1.1",
    "mysql2": "^3.22.2",
    "pdf-parse": "1.1.1",
    "turndown": "^7.2.4",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@10.21.0+sha512.da3337267e400fdd3d479a6c68079ac6db01d8ca4f67572083e722775a796788a7a9956613749e000fac20d424b594f7a791a5f4e2e13581c5ef947f26968a40"
}
