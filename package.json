{
  "name": "nena-website",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "check": "astro check",
    "inventory:legacy": "node scripts/build-legacy-inventory.mjs",
    "inventory:legacy:quick": "node scripts/build-legacy-inventory.mjs --no-crawl-assets",
    "redirects:legacy": "node scripts/build-cloudflare-redirects.mjs",
    "check:internal-links": "node scripts/check-internal-links.mjs",
    "build:cf": "ASTRO_BASE_PATH=/ npm run build",
    "check:internal-links:cf": "ASTRO_BASE_PATH=/ npm run build && ASTRO_BASE_PATH=/ npm run check:internal-links"
  },
  "dependencies": {
    "@astrojs/tailwind": "^5.1.0",
    "astro": "^5.15.8",
    "tailwindcss": "^3.4.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@tailwindcss/typography": "^0.5.19",
    "typescript": "^5.9.3"
  }
}
