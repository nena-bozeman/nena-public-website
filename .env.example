# Optional. Mailchimp-hosted signup URL (eepurl or hosted form link from Audience → signup forms).
# PUBLIC_MAILCHIMP_URL=
# Browser map (Vite/Astro): Application restrictions → HTTP referrers → e.g. https://yoursite.github.io/* and http://localhost:4321/*
PUBLIC_GOOGLE_MAPS_API_KEY=your_key_here
# Geocoding CLI (pnpm geocode:businesses): must be a different key — NOT referrer-restricted (Node has no browser referer). Use IP restriction or None; enable Geocoding API. See script header in scripts/geocode-business-addresses.mjs
# GOOGLE_MAPS_GEOCODE_KEY=
PUBLIC_GOOGLE_CALENDAR_ID=nenabozeman@gmail.com
