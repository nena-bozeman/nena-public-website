---
import Base from '../../../layouts/Base.astro';
import NewsList from '../../../components/news/NewsList.astro';
import NewsPagination from '../../../components/news/NewsPagination.astro';
import NewsPageShell from '../../../components/news/NewsPageShell.astro';
import { getCollection } from 'astro:content';
import {
  NEWS_PER_PAGE,
  sortNewsByDateDesc,
  totalNewsPages,
  collectUniqueNewsTags,
  newsEntriesForSite,
} from '../../../utils/news';
import { withSiteBase } from '../../../utils/site-link';

export async function getStaticPaths() {
  const allNews = newsEntriesForSite(await getCollection('news'));
  const sorted = sortNewsByDateDesc(allNews);
  const total = totalNewsPages(sorted.length);
  if (total <= 1) return [];
  return Array.from({ length: total - 1 }, (_, i) => ({
    params: { page: String(i + 2) },
  }));
}

const allNews = newsEntriesForSite(await getCollection('news'));
const allTags = collectUniqueNewsTags(allNews);
const sortedNews = sortNewsByDateDesc(allNews);
const totalPages = totalNewsPages(sortedNews.length);

const raw = Astro.params.page;
const pageNum = parseInt(typeof raw === 'string' ? raw : '', 10);

if (
  !Number.isFinite(pageNum) ||
  pageNum < 2 ||
  pageNum > totalPages ||
  totalPages <= 1
) {
  return Astro.redirect(withSiteBase('/news'));
}

const paginatedNews = sortedNews.slice(
  (pageNum - 1) * NEWS_PER_PAGE,
  pageNum * NEWS_PER_PAGE,
);

const title = `News — Page ${pageNum}`;
---

<Base
  title={title}
  description="Latest news from the Northeast Neighborhood Association"
  canonicalURL={`/news/page/${pageNum}`}
>
  <NewsPageShell allTags={allTags} activeTag={null}>
    <NewsList posts={paginatedNews} />
    <NewsPagination currentPage={pageNum} totalPages={totalPages} />
  </NewsPageShell>
</Base>
