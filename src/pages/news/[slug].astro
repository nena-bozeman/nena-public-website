---
import Base from '../../layouts/Base.astro';
import NewsDraftBadge from '../../components/news/NewsDraftBadge.astro';
import RelatedContent from '../../components/related/RelatedContent.astro';
import TopicPills from '../../components/related/TopicPills.astro';
import { getCollection } from 'astro:content';
import { newsEntriesForSite } from '../../utils/news';
import {
  backlinksFor,
  loadSiteContent,
  relatedEventsByTopics,
  relatedObjectivesByTopics,
} from '../../utils/related-content';

export async function getStaticPaths() {
  const news = await getCollection('news');
  return newsEntriesForSite(news).map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
const content = await loadSiteContent();
const topics = post.data.topics;
---

<Base 
  title={post.data.title} 
  description={post.data.summary}
  canonicalURL={`/news/${post.slug}`}
>
  <article class="max-w-3xl mx-auto px-4 py-12">
    <a href={`${import.meta.env.BASE_URL}news`} class="text-accent hover:text-amber-700 text-sm font-medium mb-8 inline-block transition-colors">← Back to News</a>
    
    <div class="mb-6">
      <div class="flex items-center gap-3 mb-3">
        <time class="text-sm font-medium text-accent uppercase tracking-wide">
          {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
        {post.data.author && <span class="text-sm text-gray-400">by {post.data.author}</span>}
      </div>
      <h1 class="font-serif text-4xl font-bold text-primary flex flex-wrap items-center gap-3">
        {post.data.title}
        <NewsDraftBadge show={post.data.draft} />
      </h1>
      <p class="text-xl text-gray-600 mt-3">{post.data.summary}</p>
      <TopicPills topics={topics} tags={post.data.tags} />
    </div>
    
    <div class="prose prose-green max-w-none">
      <Content />
    </div>

    <RelatedContent
      relatedObjectives={relatedObjectivesByTopics(content.objectives, topics)}
      relatedEvents={relatedEventsByTopics(content.events, topics, post.slug)}
      backlinks={backlinksFor(content.backlinkIndex, 'news', post.slug)}
      excludeNewsSlug={post.slug}
    />
  </article>
</Base>
