---
import Base from '../../layouts/Base.astro';
import NewsList from '../../components/news/NewsList.astro';
import { getCollection } from 'astro:content';

const allNews = await getCollection('news');
const sortedNews = allNews.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const page = 1;
const perPage = 10;
const paginatedNews = sortedNews.slice((page - 1) * perPage, page * perPage);
const totalPages = Math.ceil(sortedNews.length / perPage);
---

<Base title="News" description="Latest news from the Northeast Neighborhood Association">
  <div class="max-w-4xl mx-auto px-4 py-12">
    <h1 class="font-serif text-4xl font-bold text-primary mb-8">Neighborhood News</h1>
    <NewsList posts={paginatedNews} />
    {totalPages > 1 && (
      <div class="mt-8 text-center text-sm text-gray-500">
        Page {page} of {totalPages}
      </div>
    )}
  </div>
</Base>
