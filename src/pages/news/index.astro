---
import Base from '../../layouts/Base.astro';
import NewsList from '../../components/news/NewsList.astro';
import NewsPagination from '../../components/news/NewsPagination.astro';
import NewsPageShell from '../../components/news/NewsPageShell.astro';
import { getCollection } from 'astro:content';
import {
  NEWS_PER_PAGE,
  sortNewsByDateDesc,
  totalNewsPages,
  collectUniqueNewsTopics,
  newsEntriesForSite,
} from '../../utils/news';

const allNews = newsEntriesForSite(await getCollection('news'));
const filterTopics = collectUniqueNewsTopics(allNews);
const sortedNews = sortNewsByDateDesc(allNews);

const page = 1;
const totalPages = totalNewsPages(sortedNews.length);
const paginatedNews = sortedNews.slice(0, NEWS_PER_PAGE);
---

<Base title="News" description="Latest news from the Northeast Neighborhood Association">
  <NewsPageShell filterTopics={filterTopics}>
    <NewsList posts={paginatedNews} />
    <NewsPagination currentPage={page} totalPages={totalPages} />
  </NewsPageShell>
</Base>
