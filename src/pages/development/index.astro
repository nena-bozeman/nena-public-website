---
import Base from '../../layouts/Base.astro';
import CurrentPastFilters from '../../components/filters/CurrentPastFilters.astro';
import ProjectCard from '../../components/development/ProjectCard.astro';
import ProjectMap from '../../components/development/ProjectMap.astro';
import { getCollection } from 'astro:content';
import { getMailchimpSignupUrl } from '../../utils/mailchimp';
import { matchesListStatus, parseListStatus } from '../../utils/list-status';

const filterStatus = parseListStatus(Astro.url.search);
const allProjects = await getCollection('development');
const projects = allProjects
  .filter((p) => matchesListStatus(p.data.status, filterStatus))
  .sort((a, b) => b.data.dateUpdated.valueOf() - a.data.dateUpdated.valueOf());

const pageTitle = filterStatus === 'past' ? 'Past Development Projects' : 'Development Watch';
const pageDescription =
  filterStatus === 'past'
    ? 'Former development proposals and projects tracked by NENA in the Northeast Neighborhood.'
    : 'Tracking development projects in the Northeast Neighborhood of Bozeman, MT';

const mailchimpUrl = getMailchimpSignupUrl();
---

<Base title={pageTitle} description={pageDescription}>
  <div class="max-w-7xl mx-auto px-4 py-12">
    <h1 class="font-serif text-4xl font-bold text-primary mb-3">{pageTitle}</h1>
    <CurrentPastFilters pagePath="development" activeStatus={filterStatus} />
    <p class="text-gray-600 text-lg mb-8">
      {
        filterStatus === 'past'
          ? 'Completed or inactive projects kept on record from Development Watch.'
          : 'Tracking development proposals and projects in the Northeast Neighborhood.'
      }
    </p>
    {filterStatus === 'current' && <ProjectMap projects={projects} />}
    {
      projects.length === 0 ? (
        <p class="text-gray-500 text-center py-12">
          No {filterStatus === 'past' ? 'past' : 'current'} development projects to show.
        </p>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mt-8">
          {projects.map((project) => (
            <ProjectCard
              slug={project.slug}
              title={project.data.title}
              phase={project.data.phase}
              address={project.data.address}
              developer={project.data.developer}
              summary={project.data.summary}
              dateUpdated={project.data.dateUpdated}
              cityPlanningUrl={project.data.cityPlanningUrl}
              tags={project.data.tags}
            />
          ))}
        </div>
      )
    }
    {
      filterStatus === 'current' && (
        <div class="mt-10 bg-primary text-white rounded-lg p-6 text-center">
          <h2 class="font-serif text-xl font-bold mb-2">Stay Informed</h2>
          <a
            href={mailchimpUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="bg-accent hover:bg-amber-600 text-white font-semibold px-6 py-2 rounded-lg transition-colors inline-block"
          >
            Subscribe to Development Alerts
          </a>
        </div>
      )
    }
  </div>
</Base>
