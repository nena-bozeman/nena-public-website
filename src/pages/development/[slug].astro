---
import Base from '../../layouts/Base.astro';
import RelatedContent from '../../components/related/RelatedContent.astro';
import TopicPills from '../../components/related/TopicPills.astro';
import { DEVELOPMENT_PHASE_BADGE } from '../../schemas/development-phase';
import { getCollection } from 'astro:content';
import {
  backlinksFor,
  loadSiteContent,
  newsBySlugs,
  relatedEventsByTopics,
  relatedNewsByTopics,
  relatedObjectivesByTopics,
} from '../../utils/related-content';

export async function getStaticPaths() {
  const projects = await getCollection('development');
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const base = import.meta.env.BASE_URL;
const { project } = Astro.props;
const { Content } = await project.render();
const content = await loadSiteContent();
const topics = project.data.topics;

const phaseBadge = DEVELOPMENT_PHASE_BADGE[project.data.phase];
const explicitNews = newsBySlugs(content.news, project.data.newsSlugs ?? []);
const topicNews = relatedNewsByTopics(content.news, topics);
const relatedNews = [...explicitNews, ...topicNews.filter((p) => !explicitNews.some((e) => e.slug === p.slug))];
---

<Base
  title={project.data.title}
  description={project.data.summary}
  canonicalURL={`/development/${project.slug}`}
>
  <article class="max-w-3xl mx-auto px-4 py-12">
    <a href={`${base}development`} class="text-accent hover:text-amber-700 text-sm font-medium mb-8 inline-block transition-colors">← Back to Development Watch</a>

    <div class="mb-6">
      <span class={`text-xs font-semibold px-2.5 py-1 rounded-full ${phaseBadge.color}`}>
        {phaseBadge.label}
      </span>
      <h1 class="font-serif text-4xl font-bold text-primary mt-4">{project.data.title}</h1>
      <p class="text-sm text-gray-500 mt-3">📍 {project.data.address}</p>
      {project.data.developer && (
        <p class="text-sm text-gray-500 mt-1">Developer: {project.data.developer}</p>
      )}
      <p class="text-sm text-gray-400 mt-2">
        Last updated {project.data.dateUpdated.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
      </p>
      {project.data.submittedDate && (
        <p class="text-sm text-gray-400">
          Submitted {project.data.submittedDate.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
        </p>
      )}
      <p class="text-xl text-gray-600 mt-4">{project.data.summary}</p>
      <TopicPills topics={topics} />
      {project.data.cityPlanningUrl && (
        <a
          href={project.data.cityPlanningUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block mt-6 text-accent hover:text-amber-700 text-sm font-semibold transition-colors"
        >
          City Planning Docs →
        </a>
      )}
    </div>

    <div class="prose prose-green max-w-none">
      <Content />
    </div>

    <RelatedContent
      relatedNews={relatedNews}
      relatedEvents={relatedEventsByTopics(content.events, topics)}
      relatedObjectives={relatedObjectivesByTopics(content.objectives, topics)}
      backlinks={backlinksFor(content.backlinkIndex, 'development', project.slug)}
    />
  </article>
</Base>
