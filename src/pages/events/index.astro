---
import Base from '../../layouts/Base.astro';
import EventsIndexSections from '../../components/events/EventsIndexSections.astro';
import { getCollection } from 'astro:content';
import {
  EVENTS_PER_PAGE,
  sortPastEventsDesc,
  sortUpcomingEventsAsc,
  totalPastEventPages,
} from '../../utils/events';

const now = new Date();
const allEvents = await getCollection('events');

const upcoming = sortUpcomingEventsAsc(
  allEvents.filter((e) => e.data.startDate >= now),
);

const pastAll = sortPastEventsDesc(
  allEvents.filter((e) => e.data.startDate < now),
);

const totalPastPages = totalPastEventPages(pastAll.length);
const pastPage = 1;
const pastPaginated = pastAll.slice(0, EVENTS_PER_PAGE);
---

<Base title="Events" description="Upcoming events in the Northeast Neighborhood of Bozeman, MT">
  <EventsIndexSections
    upcoming={upcoming}
    pastPaginated={pastPaginated}
    pastPage={pastPage}
    totalPastPages={totalPastPages}
  />
</Base>
