---
import Base from '../../layouts/Base.astro';
import BusinessList from '../../components/businesses/BusinessList.astro';
import BusinessMap from '../../components/businesses/BusinessMap.astro';
import { getCollection } from 'astro:content';

const allBusinesses = await getCollection('businesses');
const openBusinesses = allBusinesses.filter((b) => b.data.status === 'open');
const closedCount = allBusinesses.filter((b) => b.data.status === 'closed').length;

const categories = [
  { value: '', label: 'All Categories' },
  { value: 'food-drink', label: 'Food & Drink' },
  { value: 'retail', label: 'Retail' },
  { value: 'services', label: 'Services' },
  { value: 'arts-culture', label: 'Arts & Culture' },
  { value: 'fitness-wellness', label: 'Fitness & Wellness' },
  { value: 'nonprofit', label: 'Nonprofit' },
  { value: 'other', label: 'Other' },
];
---

<Base title="Business Directory" description="Discover local businesses in the Northeast Neighborhood of Bozeman, Montana">
  <div class="max-w-7xl mx-auto px-4 py-12">
    <h1 class="font-serif text-4xl font-bold text-primary mb-4">Business Directory</h1>
    <div class="mb-8">
      <p class="text-gray-600">Supporting local businesses in the Northeast Neighborhood.</p>
      {closedCount > 0 && (
        <p class="text-sm text-gray-500 mt-2">
          <a href={`${import.meta.env.BASE_URL}businesses/archive`} class="text-accent hover:text-amber-700 font-medium transition-colors">
            Past businesses (archive)
          </a>
          <span class="text-gray-400"> — {closedCount} closed listing{closedCount === 1 ? '' : 's'}</span>
        </p>
      )}
    </div>

    <div class="flex flex-wrap items-center gap-4 mb-8">
      <div class="flex flex-wrap gap-2" id="category-filters">
        {categories.map((cat) => (
          <button
            data-category={cat.value}
            class={`px-4 py-2 rounded-full text-sm font-medium transition-colors category-filter ${cat.value === '' ? 'bg-primary text-white' : 'bg-white text-gray-600 border border-gray-200 hover:border-primary'}`}
          >
            {cat.label}
          </button>
        ))}
      </div>
      <div class="ml-auto flex gap-2">
        <button id="list-view-btn" class="px-4 py-2 rounded-sm text-sm font-medium bg-primary text-white transition-colors">List</button>
        <button id="map-view-btn" class="px-4 py-2 rounded-sm text-sm font-medium bg-white text-gray-600 border border-gray-200 hover:border-primary transition-colors">Map</button>
      </div>
    </div>

    <div id="list-view">
      <BusinessList businesses={openBusinesses} />
    </div>
    
    <div id="map-view" class="hidden">
      <BusinessMap businesses={openBusinesses} />
    </div>

    <script is:inline>
      (function () {
        if (new URLSearchParams(location.search).get('view') === 'map') {
          document.getElementById('list-view')?.classList.add('hidden');
          document.getElementById('map-view')?.classList.remove('hidden');
          var listBtn = document.getElementById('list-view-btn');
          var mapBtn = document.getElementById('map-view-btn');
          if (listBtn && mapBtn) {
            listBtn.classList.remove('bg-primary', 'text-white');
            listBtn.classList.add('bg-white', 'text-gray-600', 'border', 'border-gray-200');
            mapBtn.classList.remove('bg-white', 'text-gray-600', 'border', 'border-gray-200');
            mapBtn.classList.add('bg-primary', 'text-white');
          }
        }
      })();
    </script>
  </div>
</Base>

<script>
  const VIEW_PARAM = 'view';
  type DirectoryView = 'list' | 'map';

  function parseViewFromSearch(search: string): DirectoryView {
    const v = new URLSearchParams(search).get(VIEW_PARAM);
    return v === 'map' ? 'map' : 'list';
  }

  const filterBtns = document.querySelectorAll('.category-filter');
  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      filterBtns.forEach(b => b.classList.remove('bg-primary', 'text-white'));
      filterBtns.forEach(b => b.classList.add('bg-white', 'text-gray-600', 'border', 'border-gray-200'));
      btn.classList.remove('bg-white', 'text-gray-600', 'border', 'border-gray-200');
      btn.classList.add('bg-primary', 'text-white');
      const category = (btn as HTMLButtonElement).dataset.category ?? '';
      const cards = document.querySelectorAll('[data-business-category]');
      cards.forEach(card => {
        const el = card as HTMLElement;
        if (!category || el.dataset.businessCategory === category) {
          el.style.display = '';
        } else {
          el.style.display = 'none';
        }
      });
      window.dispatchEvent(new CustomEvent('nena-businesses-filter', { detail: { category } }));
    });
  });

  const listViewBtn = document.getElementById('list-view-btn');
  const mapViewBtn = document.getElementById('map-view-btn');
  const listView = document.getElementById('list-view');
  const mapView = document.getElementById('map-view');

  const activeBtn =
    'px-4 py-2 rounded-sm text-sm font-medium bg-primary text-white transition-colors';
  const inactiveBtn =
    'px-4 py-2 rounded-sm text-sm font-medium bg-white text-gray-600 border border-gray-200 hover:border-primary transition-colors';

  function setViewButtons(view: DirectoryView) {
    if (!listViewBtn || !mapViewBtn) return;
    if (view === 'list') {
      listViewBtn.className = activeBtn;
      mapViewBtn.className = inactiveBtn;
    } else {
      mapViewBtn.className = activeBtn;
      listViewBtn.className = inactiveBtn;
    }
  }

  function setViewPanels(view: DirectoryView) {
    if (view === 'list') {
      listView?.classList.remove('hidden');
      mapView?.classList.add('hidden');
    } else {
      mapView?.classList.remove('hidden');
      listView?.classList.add('hidden');
    }
  }

  function syncViewToUrl(view: DirectoryView, replace: boolean) {
    const url = new URL(location.href);
    if (view === 'list') {
      url.searchParams.delete(VIEW_PARAM);
    } else {
      url.searchParams.set(VIEW_PARAM, view);
    }
    const next = url.pathname + url.search + url.hash;
    if (replace) {
      history.replaceState({ view }, '', next);
    } else {
      history.pushState({ view }, '', next);
    }
  }

  function applyView(view: DirectoryView, options: { updateUrl?: boolean; replaceUrl?: boolean } = {}) {
    const { updateUrl = false, replaceUrl = false } = options;
    setViewPanels(view);
    setViewButtons(view);
    if (updateUrl) syncViewToUrl(view, replaceUrl);
    window.dispatchEvent(new CustomEvent('nena-businesses-view', { detail: { view } }));
  }

  applyView(parseViewFromSearch(location.search), { updateUrl: true, replaceUrl: true });

  listViewBtn?.addEventListener('click', () => {
    applyView('list', { updateUrl: true });
  });

  mapViewBtn?.addEventListener('click', () => {
    applyView('map', { updateUrl: true });
  });

  window.addEventListener('popstate', () => {
    applyView(parseViewFromSearch(location.search));
  });
</script>
