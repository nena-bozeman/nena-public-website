---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const businesses = await getCollection('businesses');
  return businesses.map((business) => ({
    params: { slug: business.slug },
    props: { business },
  }));
}

const base = import.meta.env.BASE_URL;
const { business } = Astro.props;
const { Content } = await business.render();

const categoryLabels: Record<string, string> = {
  'food-drink': 'Food & Drink',
  retail: 'Retail',
  services: 'Services',
  'arts-culture': 'Arts & Culture',
  'fitness-wellness': 'Fitness & Wellness',
  nonprofit: 'Nonprofit',
  other: 'Other',
};

const categoryColors: Record<string, string> = {
  'food-drink': 'bg-orange-100 text-orange-800',
  retail: 'bg-blue-100 text-blue-800',
  services: 'bg-gray-100 text-gray-800',
  'arts-culture': 'bg-purple-100 text-purple-800',
  'fitness-wellness': 'bg-green-100 text-green-800',
  nonprofit: 'bg-teal-100 text-teal-800',
  other: 'bg-gray-100 text-gray-800',
};

const { category, name } = business.data;
const logoSrc =
  business.data.logo &&
  (business.data.logo.startsWith('http')
    ? business.data.logo
    : `${base}${business.data.logo.replace(/^\//, '')}`);
---

<Base title={name} description={`${name} — Northeast Neighborhood business directory`} canonicalURL={`/businesses/${business.slug}`}>
  <article class="max-w-3xl mx-auto px-4 py-12">
    <a href={`${base}businesses`} class="text-accent hover:text-amber-700 text-sm font-medium mb-8 inline-block transition-colors">← Back to Business Directory</a>

    <div class="flex flex-wrap items-start gap-4 mb-6">
      {logoSrc && (
        <img src={logoSrc} alt={`${name} logo`} class="h-16 w-16 object-contain rounded border border-gray-100 bg-white p-1" loading="lazy" />
      )}
      <div class="flex-1 min-w-0">
        <span class={`text-xs font-medium px-2 py-0.5 rounded-full ${categoryColors[category] ?? 'bg-gray-100 text-gray-800'}`}>
          {categoryLabels[category] ?? category}
        </span>
        <h1 class="font-serif text-4xl font-bold text-primary mt-2">{name}</h1>
        <p class="text-sm text-gray-600 mt-2">📍 {business.data.address}</p>
        {business.data.founded && <p class="text-sm text-gray-400 mt-1">Est. {business.data.founded}</p>}
        {business.data.status === 'closed' && (
          <p class="text-sm font-medium text-red-700 mt-2">
            This business has closed
            {business.data.closedYear != null ? ` (${business.data.closedYear})` : ''}.{' '}
            <a href={`${base}businesses/archive`} class="underline hover:text-red-900">
              View archive
            </a>
          </p>
        )}
        <div class="flex flex-wrap gap-4 mt-4">
          {business.data.website && (
            <a
              href={business.data.website}
              target="_blank"
              rel="noopener noreferrer"
              class="text-accent hover:text-amber-700 text-sm font-semibold transition-colors"
            >
              Visit Website →
            </a>
          )}
          {business.data.phone && <span class="text-sm text-gray-600">{business.data.phone}</span>}
        </div>
      </div>
    </div>

    <div class="prose prose-green max-w-none">
      <Content />
    </div>
  </article>
</Base>
