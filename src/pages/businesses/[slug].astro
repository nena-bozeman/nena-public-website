---
import { getCollection } from 'astro:content';
import { LIST_STATUS_PAST_SEGMENT } from '../../schemas/list-status';
import { withSiteBase } from '../../utils/site-link';

void withSiteBase;

export async function getStaticPaths() {
  const places = await getCollection('places');
  return places
    .filter((place) => place.slug !== LIST_STATUS_PAST_SEGMENT)
    .map((place) => ({
      params: { slug: place.slug },
    }));
}

const { slug } = Astro.params;
if (!slug) {
  return Astro.redirect(withSiteBase('/places'));
}
return Astro.redirect(withSiteBase(`/places/${slug}`));
---
