---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const entries = await getCollection('history');
  return entries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const base = import.meta.env.BASE_URL;
const { entry } = Astro.props;
const { Content } = await entry.render();

const categoryColors: Record<string, string> = {
  founding: 'bg-amber-100 text-amber-800',
  development: 'bg-blue-100 text-blue-800',
  community: 'bg-green-100 text-green-800',
  landmark: 'bg-purple-100 text-purple-800',
  other: 'bg-gray-100 text-gray-800',
};

const { category } = entry.data;
const imageSrc =
  entry.data.image &&
  (entry.data.image.startsWith('http')
    ? entry.data.image
    : `${base}${entry.data.image.replace(/^\//, '')}`);
---

<Base
  title={entry.data.title}
  description={`${entry.data.year}: ${entry.data.title}`}
  canonicalURL={`/history/${entry.slug}`}
>
  <article class="max-w-3xl mx-auto px-4 py-12">
    <a href={`${base}history`} class="text-accent hover:text-amber-700 text-sm font-medium mb-8 inline-block transition-colors">← Back to Neighborhood History</a>

    <div class="mb-6">
      <div class="flex flex-wrap items-center gap-2 mb-3">
        <span class="text-sm font-bold text-primary font-serif">{entry.data.year}</span>
        <span class={`text-xs font-medium px-2 py-0.5 rounded-full ${categoryColors[category] ?? categoryColors.other}`}>
          {category.charAt(0).toUpperCase() + category.slice(1)}
        </span>
      </div>
      <h1 class="font-serif text-4xl font-bold text-primary">{entry.data.title}</h1>
    </div>

    {imageSrc && (
      <figure class="mb-8">
        <img src={imageSrc} alt={entry.data.imageAlt ?? ''} class="w-full rounded-lg border border-gray-100 shadow-sm" loading="lazy" />
      </figure>
    )}

    <div class="prose prose-green max-w-none">
      <Content />
    </div>
  </article>
</Base>
