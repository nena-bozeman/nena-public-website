---
import { Image } from 'astro:assets';
import Base from '../../layouts/Base.astro';
import RelatedContent from '../../components/related/RelatedContent.astro';
import TopicPills from '../../components/related/TopicPills.astro';
import { getCollection } from 'astro:content';
import { getBusinessCoverImage } from '../../utils/business-image';
import {
  placeCategoryBadgeClass,
  placeCategoryLabels,
} from '../../utils/place-categories';
import { PLACE_TYPE_BADGE_CLASS, placeTypeLabel } from '../../utils/place-categories';
import { getWebsiteLabel } from '../../utils/website-label';
import { LIST_STATUS_PAST_SEGMENT } from '../../schemas/list-status';
import {
  backlinksFor,
  loadSiteContent,
  placeHistoryLinks,
  relatedEventsByTopics,
  relatedNewsByTopics,
} from '../../utils/related-content';

export async function getStaticPaths() {
  const places = await getCollection('places');
  return places
    .filter((place) => place.slug !== LIST_STATUS_PAST_SEGMENT)
    .map((place) => ({
      params: { slug: place.slug },
      props: { place },
    }));
}

const base = import.meta.env.BASE_URL;
const { place } = Astro.props;
const { Content } = await place.render();
const content = await loadSiteContent();

const { categories, name, placeType, topics } = place.data;
const logoSrc =
  place.data.logo &&
  (place.data.logo.startsWith('http')
    ? place.data.logo
    : `${base}${place.data.logo.replace(/^\//, '')}`);

const hero = getBusinessCoverImage(place.slug, place.data.image);
const historyLinks = placeHistoryLinks(place, content.history, base);
const relatedPages = historyLinks;
---

<Base title={name} description={`${name} — Northeast Neighborhood places directory`} canonicalURL={`/places/${place.slug}`}>
  <article class="max-w-3xl mx-auto px-4 py-12">
    <a href={`${base}places`} class="text-accent hover:text-amber-700 text-sm font-medium mb-6 inline-block transition-colors">
      ← Back to Places
    </a>

    {hero && (
      <div class="mb-8 w-full overflow-hidden rounded-xl border border-gray-200 bg-gray-100 shadow-xs aspect-2/1 max-h-88">
        <Image
          src={hero}
          alt={`${name} — photo`}
          class="h-full w-full object-cover"
          width={1200}
          height={600}
          sizes="(max-width: 768px) 100vw, 48rem"
          loading="eager"
          fetchpriority="high"
          decoding="async"
        />
      </div>
    )}

    <div class="flex flex-wrap items-start gap-4 mb-6">
      {!hero && logoSrc && (
        <img src={logoSrc} alt={`${name} logo`} class="h-16 w-16 object-contain rounded-sm border border-gray-100 bg-white p-1" loading="lazy" />
      )}
      <div class="flex-1 min-w-0">
        <div class="flex flex-wrap gap-2">
          <span class={`text-xs font-medium px-2 py-0.5 rounded-full ${PLACE_TYPE_BADGE_CLASS[placeType]}`}>
            {placeTypeLabel(placeType)}
          </span>
          {
            (categories ?? []).map((cat) => (
              <span
                class={`text-xs font-medium px-2 py-0.5 rounded-full ${placeCategoryBadgeClass[cat] ?? 'bg-gray-100 text-gray-800'}`}
              >
                {placeCategoryLabels[cat] ?? cat}
              </span>
            ))
          }
        </div>
        <h1 class="font-serif text-4xl font-bold text-primary mt-2">{name}</h1>
        {place.data.website && (
          <a
            href={place.data.website}
            target="_blank"
            rel="noopener noreferrer"
            class="text-accent hover:text-amber-700 text-sm font-semibold transition-colors break-all block mt-1.5"
          >
            {getWebsiteLabel(place.data.website)} →
          </a>
        )}
        <p class="text-sm text-gray-600 mt-2">📍 {place.data.address}</p>
        {place.data.founded && <p class="text-sm text-gray-400 mt-1">Est. {place.data.founded}</p>}
        {place.data.status === 'past' && (
          <p class="text-sm font-medium text-red-700 mt-2">
            This business has closed
            {place.data.closedYear != null ? ` (${place.data.closedYear})` : ''}.{' '}
            <a href={`${base}places/past`} class="underline hover:text-red-900">
              View past places
            </a>
          </p>
        )}
        {place.data.phone && <p class="text-sm text-gray-600 mt-2">{place.data.phone}</p>}
        <TopicPills topics={topics} />
      </div>
    </div>

    <div class="prose prose-green max-w-none">
      <Content />
    </div>

    <RelatedContent
      relatedNews={relatedNewsByTopics(content.news, topics)}
      relatedEvents={relatedEventsByTopics(content.events, topics)}
      backlinks={backlinksFor(content.backlinkIndex, 'places', place.slug)}
      relatedPages={relatedPages}
    />
  </article>
</Base>
