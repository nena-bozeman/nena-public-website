---
import Base from '../layouts/Base.astro';

const paypalUrl = 'https://www.paypal.com/donate';
---

<Base
  title="Donate"
  description="Support the Northeast Neighborhood Association through donations and community fundraisers."
>
  <div class="max-w-3xl mx-auto px-4 py-12">
    <h1 class="font-serif text-4xl font-bold text-primary mb-6">Donate to NENA</h1>

    <div class="prose prose-green max-w-none mb-8">

      <p class="text-gray-700">
        If you'd like to support NENA, please use the PayPal button below. <br/>
        To mail a check, please contact us at <a href="mailto:NENABozeman@gmail.com" class="text-accent hover:text-amber-700 font-medium">NENABozeman@gmail.com</a>.
      </p>
      <p class="text-gray-700">
        If you'd like to support NENA, by buying a logo sticker, come to an event or email us at <a href="mailto:NENABozeman@gmail.com" class="text-accent hover:text-amber-700 font-medium">NENABozeman@gmail.com</a>.
      </p>
    </div>

    <div class="bg-cream rounded-lg p-8 border border-amber-100 text-center">
      <p class="text-primary font-serif text-xl font-semibold mb-4">Support neighborhood programs</p>
      <a
        href={paypalUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-block bg-accent hover:bg-amber-600 text-white font-semibold px-8 py-3 rounded-lg transition-colors"
      >
        Donate with PayPal
      </a>
    </div>
  </div>
</Base>
