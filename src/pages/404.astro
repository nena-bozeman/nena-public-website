---
import Base from '../layouts/Base.astro';
---
<Base title="Page Not Found">
  <div class="max-w-2xl mx-auto px-4 py-24 text-center">
    <p class="text-8xl font-serif font-bold text-accent mb-4">404</p>
    <h1 class="font-serif text-3xl font-bold text-primary mb-4">Page Not Found</h1>
    <p class="text-gray-600 mb-8">We couldn't find what you were looking for.</p>
    <a href="/" class="bg-primary hover:bg-green-800 text-white font-semibold px-6 py-3 rounded-lg transition-colors inline-block">Go Home</a>
  </div>
</Base>
