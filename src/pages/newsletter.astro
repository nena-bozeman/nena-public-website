---
import Base from '../layouts/Base.astro';
import NewsList from '../components/news/NewsList.astro';
import { getCollection } from 'astro:content';
import { newsMatchingTopics } from '../utils/content-relationships';
import { getMailchimpSignupUrl } from '../utils/mailchimp';
import { newsEntriesForSite } from '../utils/news';

const mailchimpUrl = getMailchimpSignupUrl();
const newsletters = newsMatchingTopics(newsEntriesForSite(await getCollection('news')), ['newsletter']);
---

<Base
  title="Newsletter"
  description="Sign up for NENA email updates and browse past neighborhood newsletters for the Northeast Neighborhood, Bozeman."
>
  <div class="max-w-4xl mx-auto px-4 py-12">
    <h1 class="font-serif text-4xl font-bold text-primary mb-3">Newsletter</h1>
    <p class="text-xl text-gray-600 mb-8">
      Stay informed about meetings, events, and advocacy. NENA publishes spring and fall editions for Northeast neighbors.
    </p>

    <section
      class="bg-white rounded-lg shadow-xs border border-gray-100 p-8 mb-12"
      aria-labelledby="newsletter-signup-heading"
    >
      <h2 id="newsletter-signup-heading" class="font-serif text-2xl font-bold text-primary mb-4">
        Sign up for email updates
      </h2>
      <p class="text-gray-700 mb-4">
        Subscriptions are handled on Mailchimp’s hosted page so the form always matches your list settings. You’ll leave
        this site briefly to complete signup; optional fields (address, etc.) are only on Mailchimp’s page.
      </p>
      <a
        href={mailchimpUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-block rounded-lg bg-accent px-6 py-3 font-semibold text-white shadow-xs transition-colors hover:bg-amber-600"
      >
        Open Mailchimp signup form →
      </a>
    </section>

    <section aria-labelledby="newsletter-archive-heading">
      <h2 id="newsletter-archive-heading" class="font-serif text-2xl font-bold text-primary mb-6">
        Past newsletters
      </h2>
      <NewsList
        posts={newsletters}
        showTags={false}
        emptyMessage="Past newsletter issues will appear here as they are migrated from the legacy site."
      />
    </section>
  </div>
</Base>
