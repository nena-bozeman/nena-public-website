---
import Base from '../layouts/Base.astro';
import { getMailchimpSignupUrl } from '../utils/mailchimp';

const mailchimpUrl = getMailchimpSignupUrl();
---

<Base
  title="Newsletter"
  description="Sign up for NENA email updates for the Northeast Neighborhood, Bozeman."
>
  <div class="max-w-2xl mx-auto px-4 py-12">
    <h1 class="font-serif text-4xl font-bold text-primary mb-4">Newsletter signup</h1>
    <p class="text-gray-700 text-lg mb-8">
      Stay informed about meetings, events, and advocacy. Subscriptions are handled on Mailchimp’s hosted page so the form always matches your list settings.
    </p>


      <p class="text-lg text-gray-700 mb-6">
        You’ll leave this site briefly to complete signup. Optional fields (address, etc.) are only on Mailchimp’s page.
      </p>
      <a
        href={mailchimpUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-block rounded-lg bg-accent px-6 py-3 font-semibold text-white shadow-sm transition-colors hover:bg-amber-600"
      >
        Open Mailchimp signup form →
      </a>


    <p class="text-sm text-gray-500 mt-8">
      Past newsletter PDFs will be listed on the <a href={`${import.meta.env.BASE_URL}objectives/nena-newsletters`} class="text-accent hover:text-amber-700">NENA Newsletters</a> objective page.
    </p>
  </div>
</Base>
