---
import BusinessCard from './BusinessCard.astro';
import type { CollectionEntry } from 'astro:content';
import { businessHasCategory, type BusinessCategory } from '../../utils/business-categories';

export interface Props {
  businesses: CollectionEntry<'businesses'>[];
  selectedCategory?: string;
}

const { businesses, selectedCategory } = Astro.props;

const filtered = selectedCategory
  ? businesses.filter((b) =>
      businessHasCategory(b.data.categories, selectedCategory as BusinessCategory),
    )
  : businesses;
---

<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4" id="business-list-grid">
  {filtered.length === 0 ? (
    <p class="col-span-full text-gray-500 text-center py-8">No businesses found.</p>
  ) : (
    filtered.map((business) => (
      <div
        class="business-list-item min-h-0"
        data-categories={business.data.categories.join(',')}
      >
        <BusinessCard
          slug={business.slug}
          name={business.data.name}
          categories={business.data.categories}
          address={business.data.address}
          website={business.data.website}
          phone={business.data.phone}
          founded={business.data.founded}
          legacy={business.data.legacy}
          status={business.data.status}
          closedYear={business.data.closedYear}
          image={business.data.image}
        />
      </div>
    ))
  )}
</div>
<p id="business-category-empty" class="hidden text-gray-500 text-center py-8">
  No businesses in this category.
</p>
