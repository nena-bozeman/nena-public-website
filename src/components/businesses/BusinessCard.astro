---
export interface Props {
  name: string;
  category: string;
  address: string;
  website?: string;
  phone?: string;
  founded?: number;
  legacy?: boolean;
  active?: boolean;
}

const { name, category, address, website, phone, founded, legacy = false, active = true } = Astro.props;

const categoryLabels: Record<string, string> = {
  'food-drink': 'Food & Drink',
  'retail': 'Retail',
  'services': 'Services',
  'arts-culture': 'Arts & Culture',
  'fitness-wellness': 'Fitness & Wellness',
  'nonprofit': 'Nonprofit',
  'other': 'Other',
};

const categoryColors: Record<string, string> = {
  'food-drink': 'bg-orange-100 text-orange-800',
  'retail': 'bg-blue-100 text-blue-800',
  'services': 'bg-gray-100 text-gray-800',
  'arts-culture': 'bg-purple-100 text-purple-800',
  'fitness-wellness': 'bg-green-100 text-green-800',
  'nonprofit': 'bg-teal-100 text-teal-800',
  'other': 'bg-gray-100 text-gray-800',
};
---

<article class="bg-white rounded-lg shadow-sm hover:shadow-md transition-shadow border border-gray-100 p-5" data-business-category={category}>
  <div class="flex items-start justify-between gap-3">
    <div class="flex-1 min-w-0">
      <div class="flex items-center gap-2 mb-1 flex-wrap">
        <span class={`text-xs font-medium px-2 py-0.5 rounded-full ${categoryColors[category] ?? 'bg-gray-100 text-gray-800'}`}>
          {categoryLabels[category] ?? category}
        </span>
        {legacy && <span class="text-xs font-medium px-2 py-0.5 rounded-full bg-amber-100 text-amber-800">Legacy 10+</span>}
        {!active && <span class="text-xs font-medium px-2 py-0.5 rounded-full bg-red-100 text-red-800">Closed</span>}
      </div>
      <h3 class="font-serif font-bold text-primary text-lg">{name}</h3>
      <p class="text-sm text-gray-500 mt-1">📍 {address}</p>
      {founded && <p class="text-xs text-gray-400 mt-1">Est. {founded}</p>}
    </div>
  </div>
  <div class="mt-4 flex items-center gap-4">
    {website && (
      <a href={website} target="_blank" rel="noopener noreferrer" class="text-accent hover:text-amber-700 text-sm font-medium transition-colors">
        Visit Website →
      </a>
    )}
    {phone && <span class="text-sm text-gray-500">{phone}</span>}
  </div>
</article>
