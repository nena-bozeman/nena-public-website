---
import Base from '../../layouts/Base.astro';
import CurrentPastFilters from '../filters/CurrentPastFilters.astro';
import ListStatusLegacyRedirect from '../filters/ListStatusLegacyRedirect.astro';
import PlaceTypeFilters from '../filters/PlaceTypeFilters.astro';
import BusinessList from './BusinessList.astro';
import BusinessMap from './BusinessMap.astro';
import { getCollection } from 'astro:content';
import { placeCategoryFilterOptions, type PlaceType } from '../../utils/place-categories';
import { matchesListStatus, type ListStatus } from '../../utils/list-status';

export interface Props {
  filterStatus: ListStatus;
}

const { filterStatus } = Astro.props;
const allBusinesses = await getCollection('places');
const filtered = allBusinesses.filter((b) => matchesListStatus(b.data.status, filterStatus));
const businesses =
  filterStatus === 'past'
    ? [...filtered].sort((a, b) => {
        const ya = a.data.closedYear ?? 0;
        const yb = b.data.closedYear ?? 0;
        if (yb !== ya) return yb - ya;
        return a.data.name.localeCompare(b.data.name);
      })
    : filtered;

const pageTitle = filterStatus === 'past' ? 'Past Places' : 'Places';
const pageDescription =
  filterStatus === 'past'
    ? 'Former Northeast Neighborhood businesses and other places kept on record for neighborhood history.'
    : 'Businesses, parks, and landmarks in the Northeast Neighborhood of Bozeman, Montana';

const categories = placeCategoryFilterOptions(businesses);
const showCategoryFilters = categories.length > 1;
const placeTypesPresent = [
  ...new Set(businesses.map((b) => b.data.placeType)),
] as PlaceType[];
const defaultView = filterStatus === 'past' ? 'list' : 'map';
const listInitiallyHidden = defaultView !== 'list';
const mapInitiallyHidden = defaultView !== 'map';
---

<Base title={pageTitle} description={pageDescription}>
  <div class="max-w-7xl mx-auto px-4 py-12" data-default-view={defaultView}>
    <h1 class="font-serif text-4xl font-bold text-primary mb-4">{pageTitle}</h1>
    <CurrentPastFilters pagePath="places" activeStatus={filterStatus} />
    {
      filterStatus === 'past' ? (
        <p class="text-gray-600 mb-8 max-w-2xl">
          Listings for businesses that have closed remain here for reference. Year shown is when they
          closed, when known.
        </p>
      ) : (
        <p class="text-gray-600 mb-8">Supporting local businesses, parks, and landmarks in the Northeast Neighborhood.</p>
      )
    }

    <div class="flex flex-wrap items-center gap-4 mb-8">
      <PlaceTypeFilters availableTypes={placeTypesPresent} />
      {
        showCategoryFilters && (
          <div class="flex flex-wrap gap-2" id="category-filters">
            {categories.map((cat) => (
              <button
                type="button"
                data-category={cat.value === '' ? 'all' : cat.value}
                class={`px-4 py-2 rounded-full text-sm font-medium transition-colors category-filter ${cat.value === '' ? 'bg-primary text-white' : 'bg-white text-gray-600 border border-gray-200 hover:border-primary'}`}
              >
                {cat.label}
              </button>
            ))}
          </div>
        )
      }
      <div class="ml-auto flex gap-2">
        <button
          id="list-view-btn"
          class={`px-4 py-2 rounded-sm text-sm font-medium transition-colors ${defaultView === 'list' ? 'bg-primary text-white' : 'bg-white text-gray-600 border border-gray-200 hover:border-primary'}`}
        >
          List
        </button>
        <button
          id="map-view-btn"
          class={`px-4 py-2 rounded-sm text-sm font-medium transition-colors ${defaultView === 'map' ? 'bg-primary text-white' : 'bg-white text-gray-600 border border-gray-200 hover:border-primary'}`}
        >
          Map
        </button>
      </div>
    </div>

    <div id="list-view" class:list={[listInitiallyHidden && 'hidden']}>
      <BusinessList businesses={businesses} />
    </div>

    <div id="map-view" class:list={[mapInitiallyHidden && 'hidden']}>
      <BusinessMap businesses={businesses} />
    </div>

    <script is:inline>
      (function () {
        var root = document.querySelector('[data-default-view]');
        var defaultView = root?.getAttribute('data-default-view') === 'list' ? 'list' : 'map';
        var view = new URLSearchParams(location.search).get('view');
        var activeView = view === 'list' || view === 'map' ? view : defaultView;
        if (activeView === 'list') {
          document.getElementById('list-view')?.classList.remove('hidden');
          document.getElementById('map-view')?.classList.add('hidden');
          var listBtn = document.getElementById('list-view-btn');
          var mapBtn = document.getElementById('map-view-btn');
          if (listBtn && mapBtn) {
            listBtn.classList.remove('bg-white', 'text-gray-600', 'border', 'border-gray-200');
            listBtn.classList.add('bg-primary', 'text-white');
            mapBtn.classList.remove('bg-primary', 'text-white');
            mapBtn.classList.add('bg-white', 'text-gray-600', 'border', 'border-gray-200');
          }
        } else {
          document.getElementById('list-view')?.classList.add('hidden');
          document.getElementById('map-view')?.classList.remove('hidden');
          var listBtnMap = document.getElementById('list-view-btn');
          var mapBtnMap = document.getElementById('map-view-btn');
          if (listBtnMap && mapBtnMap) {
            listBtnMap.classList.remove('bg-primary', 'text-white');
            listBtnMap.classList.add('bg-white', 'text-gray-600', 'border', 'border-gray-200');
            mapBtnMap.classList.remove('bg-white', 'text-gray-600', 'border', 'border-gray-200');
            mapBtnMap.classList.add('bg-primary', 'text-white');
          }
        }
      })();
    </script>
    {filterStatus === 'current' && <ListStatusLegacyRedirect pagePath="places" />}
  </div>
</Base>

<script>
  function parseBusinessCategories(el: HTMLElement): string[] {
    return (el.getAttribute('data-categories') ?? '')
      .split(',')
      .map((c) => c.trim())
      .filter(Boolean);
  }

  function getActivePlaceType(): string {
    const el = document.querySelector<HTMLButtonElement>(
      '.place-type-filter.place-type-filter-active',
    );
    const placeType = el?.getAttribute('data-place-type') ?? 'all';
    return placeType === 'all' ? '' : placeType;
  }

  function getActiveCategory(): string {
    const el = document.querySelector<HTMLButtonElement>(
      '#category-filters button.category-filter.bg-primary',
    );
    const cat = el?.getAttribute('data-category') ?? 'all';
    return cat === 'all' ? '' : cat;
  }

  function applyPlaceFilters() {
    const placeType = getActivePlaceType();
    const category = getActiveCategory();
    const items = document.querySelectorAll<HTMLElement>('.business-list-item[data-place-type]');
    const grid = document.getElementById('business-list-grid');
    const emptyMsg = document.getElementById('business-category-empty');
    let visible = 0;

    items.forEach((el) => {
      const cats = parseBusinessCategories(el);
      const type = el.getAttribute('data-place-type') ?? '';
      const showType = !placeType || type === placeType;
      const showCategory = !category || cats.includes(category);
      const show = showType && showCategory;
      el.classList.toggle('hidden', !show);
      if (show) visible += 1;
    });

    if (grid) grid.classList.toggle('hidden', visible === 0 && items.length > 0);
    emptyMsg?.classList.toggle('hidden', visible > 0 || items.length === 0);
  }

  function applyBusinessCategoryFilter(_category: string) {
    applyPlaceFilters();
    window.dispatchEvent(
      new CustomEvent('nena-businesses-filter', {
        detail: { category: getActiveCategory(), placeType: getActivePlaceType() },
      }),
    );
  }

  const typeFilterBtns = document.querySelectorAll<HTMLButtonElement>('.place-type-filter');
  const typePillIdle =
    'inline-flex items-center rounded-full border px-3 py-1 text-sm font-medium transition-colors place-type-filter border-gray-200 bg-white text-gray-600 hover:border-primary hover:text-primary';
  const typePillSelected =
    'inline-flex items-center rounded-full border px-3 py-1 text-sm font-medium transition-colors place-type-filter place-type-filter-active border-primary bg-primary text-white';

  typeFilterBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      typeFilterBtns.forEach((b) => {
        b.className = typePillIdle;
        b.classList.remove('place-type-filter-active');
        b.setAttribute('aria-pressed', 'false');
      });
      btn.className = typePillSelected;
      btn.classList.add('place-type-filter-active');
      btn.setAttribute('aria-pressed', 'true');
      applyPlaceFilters();
      window.dispatchEvent(
        new CustomEvent('nena-businesses-filter', {
          detail: { category: getActiveCategory(), placeType: getActivePlaceType() },
        }),
      );
    });
  });

  const filterBtns = document.querySelectorAll<HTMLButtonElement>('.category-filter');
  filterBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      filterBtns.forEach((b) => {
        b.classList.remove('bg-primary', 'text-white');
        b.classList.add('bg-white', 'text-gray-600', 'border', 'border-gray-200');
      });
      btn.classList.remove('bg-white', 'text-gray-600', 'border', 'border-gray-200');
      btn.classList.add('bg-primary', 'text-white');

      applyBusinessCategoryFilter(btn.getAttribute('data-category') ?? 'all');
    });
  });
</script>

<script>
  const VIEW_PARAM = 'view';
  type DirectoryView = 'list' | 'map';

  function getDefaultView(): DirectoryView {
    const root = document.querySelector('[data-default-view]');
    return root?.getAttribute('data-default-view') === 'list' ? 'list' : 'map';
  }

  function parseViewFromSearch(search: string): DirectoryView {
    const v = new URLSearchParams(search).get(VIEW_PARAM);
    if (v === 'list' || v === 'map') return v;
    return getDefaultView();
  }

  function syncViewToUrl(view: DirectoryView, replace: boolean) {
    const url = new URL(location.href);
    if (view === getDefaultView()) {
      url.searchParams.delete(VIEW_PARAM);
    } else {
      url.searchParams.set(VIEW_PARAM, view);
    }
    const next = url.pathname + url.search + url.hash;
    if (replace) {
      history.replaceState({ view }, '', next);
    } else {
      history.pushState({ view }, '', next);
    }
  }

  const listViewBtn = document.getElementById('list-view-btn');
  const mapViewBtn = document.getElementById('map-view-btn');
  const listView = document.getElementById('list-view');
  const mapView = document.getElementById('map-view');

  const activeBtn =
    'px-4 py-2 rounded-sm text-sm font-medium bg-primary text-white transition-colors';
  const inactiveBtn =
    'px-4 py-2 rounded-sm text-sm font-medium bg-white text-gray-600 border border-gray-200 hover:border-primary transition-colors';

  function setViewButtons(view: DirectoryView) {
    if (!listViewBtn || !mapViewBtn) return;
    if (view === 'list') {
      listViewBtn.className = activeBtn;
      mapViewBtn.className = inactiveBtn;
    } else {
      mapViewBtn.className = activeBtn;
      listViewBtn.className = inactiveBtn;
    }
  }

  function setViewPanels(view: DirectoryView) {
    if (view === 'list') {
      listView?.classList.remove('hidden');
      mapView?.classList.add('hidden');
    } else {
      mapView?.classList.remove('hidden');
      listView?.classList.add('hidden');
    }
  }

  function applyView(view: DirectoryView, options: { updateUrl?: boolean; replaceUrl?: boolean } = {}) {
    const { updateUrl = false, replaceUrl = false } = options;
    setViewPanels(view);
    setViewButtons(view);
    if (updateUrl) syncViewToUrl(view, replaceUrl);
    window.dispatchEvent(new CustomEvent('nena-businesses-view', { detail: { view } }));
  }

  applyView(parseViewFromSearch(location.search), { updateUrl: true, replaceUrl: true });

  listViewBtn?.addEventListener('click', () => {
    applyView('list', { updateUrl: true });
  });

  mapViewBtn?.addEventListener('click', () => {
    applyView('map', { updateUrl: true });
  });

  window.addEventListener('popstate', () => {
    applyView(parseViewFromSearch(location.search));
  });
</script>
