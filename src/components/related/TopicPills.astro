---
import type { Topic } from '../../schemas/topics';
import { formatTopicLabel, topicListingHref } from '../../schemas/topics';
import { formatNewsTagLabel } from '../../utils/news';

export interface Props {
  topics?: Topic[];
  tags?: string[];
}

const base = import.meta.env.BASE_URL;
const { topics = [], tags = [] } = Astro.props;
---

{
  (topics.length > 0 || tags.length > 0) && (
    <div class="flex flex-wrap gap-2 mt-4">
      {
        topics.map((topic) => (
          <a
            href={topicListingHref(topic, base)}
            class="text-xs bg-green-50 text-green-800 px-2 py-1 rounded-full hover:bg-green-100 transition-colors"
          >
            {formatTopicLabel(topic)}
          </a>
        ))
      }
      {
        tags.map((tag) => (
          <a
            href={`${base}news/tag/${encodeURIComponent(tag)}`}
            class="text-xs bg-amber-50 text-amber-700 px-2 py-1 rounded-full hover:bg-amber-100 transition-colors"
          >
            {formatNewsTagLabel(tag)}
          </a>
        ))
      }
    </div>
  )
}
