---
import { getCollection } from 'astro:content';
import { buildNavGroups, getActiveObjectives } from '../../data/navigation';
import HeaderSearch from './HeaderSearch.astro';
import MobileNav from './MobileNav.astro';
import NavDropdown from './NavDropdown.astro';

const base = import.meta.env.BASE_URL;
const pathname = Astro.url.pathname;
const objectives = await getCollection('objectives');
const activeObjectives = getActiveObjectives(objectives);
const navGroups = buildNavGroups(activeObjectives);
---

<div class="flex min-w-0 flex-1 items-center justify-end gap-1 sm:gap-2">
  <nav class="hidden items-center gap-0.5 md:flex" aria-label="Main navigation">
    {navGroups.map((group) => <NavDropdown group={group} base={base} pathname={pathname} />)}
  </nav>

  <HeaderSearch />

  <button
    id="mobile-menu-btn"
    type="button"
    class="rounded-sm p-2 text-green-100 transition-colors hover:bg-green-800 hover:text-white md:hidden"
    aria-expanded="false"
    aria-controls="mobile-menu"
    aria-label="Open menu"
  >
    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
    </svg>
  </button>
</div>

<div
  id="mobile-menu"
  class="fixed inset-0 z-50 flex flex-col items-center justify-center overflow-y-auto bg-primary px-4 py-16 md:hidden"
  role="dialog"
  aria-modal="true"
  aria-label="Site menu"
  hidden
>
  <button
    id="close-menu-btn"
    type="button"
    class="absolute right-4 top-4 rounded-sm p-2 text-green-100 transition-colors hover:bg-green-800 hover:text-white focus:outline-solid focus:outline-2 focus:outline-offset-0 focus:outline-amber-300/80"
    aria-label="Close menu"
  >
    <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
    </svg>
  </button>
  <MobileNav navGroups={navGroups} base={base} pathname={pathname} />
</div>

<script>
  import '../../client/nav-dropdown';
  import '../../client/mobile-nav';
</script>
