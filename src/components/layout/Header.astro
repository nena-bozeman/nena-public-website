---
import { Image } from 'astro:assets';
import nenaLogo from '../../assets/nena-logo-lg.png';
import Navigation from './Navigation.astro';

const base = import.meta.env.BASE_URL;
const homePath = base.endsWith('/') ? base.slice(0, -1) || '/' : base;
const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
const isHome = currentPath === homePath;
---

<header class:list={['bg-primary text-white shadow-lg', isHome && 'relative z-40']} data-pagefind-ignore>
  <div
    class:list={[
      'max-w-7xl mx-auto px-4 flex justify-between',
      isHome ? 'sm:px-6' : 'py-4 items-center',
    ]}
  >
    <a
      href={base}
      class:list={[
        'shrink-0 group',
        isHome
          ? 'relative z-50 -mb-14 sm:-mb-16 md:-mb-24'
          : 'flex items-center',
      ]}
      aria-label="NENA home"
    >
      <Image
        src={nenaLogo}
        alt=""
        width={isHome ? 180 : 48}
        height={isHome ? 180 : 48}
        class:list={[
          'shrink-0 object-contain',
          isHome ? 'h-28 w-28 sm:h-32 sm:w-32 md:h-40 md:w-40' : 'h-12 w-12',
        ]}
        loading="eager"
        fetchpriority="high"
      />
    </a>
    {
      isHome ? (
        <div class="flex items-center self-start py-3 md:pt-2 md:pb-1 min-h-14 md:min-h-0">
          <Navigation />
        </div>
      ) : (
        <Navigation />
      )
    }
  </div>
</header>
