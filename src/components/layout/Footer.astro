---
import {
  buildFooterColumns,
  footerUtilityLinks,
  isNavItemActive,
  resolveNavHref,
} from '../../data/navigation';

const base = import.meta.env.BASE_URL;
const pathname = Astro.url.pathname;
const year = new Date().getFullYear();
const footerColumns = buildFooterColumns();
---

<footer class="mt-16 bg-primary text-green-100" data-pagefind-ignore>
  <div class="mx-auto max-w-7xl px-4 py-10">
    <div class="grid grid-cols-1 gap-8 md:grid-cols-2">
      <div class="flex h-full min-h-0 flex-col">
        <div>
          <h3 class="mb-3 font-serif text-lg font-bold text-white">Northeast Neighborhood Association</h3>
          <p class="text-sm text-green-200">Bozeman, Montana's Last Best Neighborhood</p>
        </div>
        <div class="mt-auto self-start pt-6">
          <img
            src={`${base}images/migrated/nenabozeman-org/files/large/nena-map.png`}
            alt="Street map of Bozeman with the Northeast Neighborhood boundary highlighted"
            class="w-full max-w-52 rounded-md border border-green-600/50 bg-white/5 object-contain shadow-md sm:max-w-xs"
            loading="lazy"
            decoding="async"
          />
        </div>
      </div>
      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
        {
          footerColumns.map((column) => (
            <div>
              <h3 class="mb-3 font-semibold text-white">{column.label}</h3>
              <ul class="space-y-1 text-sm">
                {column.links.map((link) => {
                  const active = isNavItemActive(pathname, base, link.href);
                  return (
                    <li>
                      <a
                        href={resolveNavHref(base, link.href)}
                        class:list={[
                          'transition-colors hover:text-white focus:outline-solid focus:outline-2 focus:outline-offset-2 focus:outline-amber-300/80',
                          active ? 'font-medium text-white' : '',
                        ]}
                        aria-current={active ? 'page' : undefined}
                      >
                        {link.label}
                      </a>
                    </li>
                  );
                })}
              </ul>
            </div>
          ))
        }
      </div>
    </div>
    <div class="mt-8 border-t border-green-700 pt-6 text-center text-sm text-green-300">
      <p>
        &copy; {year} Northeast Neighborhood Association · Bozeman, MT · <a
          href="mailto:NENABozeman@gmail.com"
          class="hover:text-white focus:outline-solid focus:outline-2 focus:outline-offset-2 focus:outline-amber-300/80"
        >NENABozeman@gmail.com</a>
      </p>
      <p class="mt-2">
        {
          footerUtilityLinks.map((link, index) => (
            <span>
              {index > 0 && <span aria-hidden="true"> · </span>}
              <a
                href={resolveNavHref(base, link.href)}
                class="hover:text-white focus:outline-solid focus:outline-2 focus:outline-offset-2 focus:outline-amber-300/80"
              >
                {link.label}
              </a>
            </span>
          ))
        }
      </p>
    </div>
  </div>
</footer>
