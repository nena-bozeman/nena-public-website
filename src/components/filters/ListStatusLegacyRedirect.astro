---
import { listStatusHref } from '../../utils/list-status';

export interface Props {
  pagePath: string;
}

const pastHref = listStatusHref(Astro.props.pagePath, 'past', import.meta.env.BASE_URL);
---

<script is:inline define:vars={{ pastHref }}>
  (function () {
    var q = new URLSearchParams(location.search);
    if (q.get('status') === 'past' || q.get('period') === 'past') {
      q.delete('status');
      q.delete('period');
      var rest = q.toString();
      location.replace(pastHref + (rest ? '?' + rest : ''));
    }
  })();
</script>
