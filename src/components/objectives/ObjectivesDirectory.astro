---
import Base from '../../layouts/Base.astro';
import CurrentPastFilters from '../filters/CurrentPastFilters.astro';
import ListStatusLegacyRedirect from '../filters/ListStatusLegacyRedirect.astro';
import ObjectiveList from './ObjectiveList.astro';
import { getCollection } from 'astro:content';
import { OUR_WORK_PATH } from '../../data/our-work';
import { matchesListStatus, type ListStatus } from '../../utils/list-status';

export interface Props {
  filterStatus: ListStatus;
}

const { filterStatus } = Astro.props;
const OBJECTIVE_SLUGS_TO_SKIP = new Set(['nena-newsletters']);

const allObjectives = await getCollection('objectives');
const sorted = [...allObjectives].sort((a, b) => a.data.order - b.data.order);
const objectives = sorted.filter(
  (o) => matchesListStatus(o.data.status, filterStatus) && !OBJECTIVE_SLUGS_TO_SKIP.has(o.slug),
);

const pageTitle =
  filterStatus === 'past' ? 'Past committees & objectives' : 'Our Work';
const pageDescription =
  filterStatus === 'past'
    ? 'Former NENA committees and neighborhood objectives'
    : 'Neighborhood communication, advocacy, and development watch';
---

<Base title={pageTitle} description={pageDescription}>
  <div class="max-w-5xl mx-auto px-4 py-12">
    <h1 class="font-serif text-4xl font-bold text-primary mb-4">{pageTitle}</h1>
    <CurrentPastFilters pagePath={OUR_WORK_PATH} activeStatus={filterStatus} />
    <ObjectiveList objectives={objectives} filterStatus={filterStatus} />
    {filterStatus === 'current' && <ListStatusLegacyRedirect pagePath={OUR_WORK_PATH} />}
  </div>
</Base>
