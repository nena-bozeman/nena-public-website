---
export interface Props {
  slug: string;
  title: string;
  status: string;
  address: string;
  developer?: string;
  summary: string;
  lastUpdated: Date;
  cityPlanningUrl?: string;
  tags?: string[];
}

const base = import.meta.env.BASE_URL;
const { slug, title, status, address, developer, summary, lastUpdated, cityPlanningUrl, tags = [] } = Astro.props;
const projectHref = `${base}development/${slug}`;

const statusConfig: Record<string, { color: string; label: string }> = {
  'proposed': { color: 'bg-yellow-100 text-yellow-800', label: 'Proposed' },
  'under-review': { color: 'bg-orange-100 text-orange-800', label: 'Under Review' },
  'approved': { color: 'bg-green-100 text-green-800', label: 'Approved' },
  'under-construction': { color: 'bg-blue-100 text-blue-800', label: 'Under Construction' },
  'complete': { color: 'bg-gray-100 text-gray-800', label: 'Complete' },
  'denied': { color: 'bg-red-100 text-red-800', label: 'Denied' },
};

const config = statusConfig[status] ?? { color: 'bg-gray-100 text-gray-800', label: status };
---

<article class="bg-white rounded-lg shadow-sm hover:shadow-md transition-shadow border border-gray-100 p-6">
  <div class="flex items-center gap-2 mb-2">
    <span class={`text-xs font-semibold px-2.5 py-1 rounded-full ${config.color}`}>
      {config.label}
    </span>
  </div>
  <h3 class="font-serif font-bold text-primary text-lg mb-1">
    <a href={projectHref} class="hover:text-accent transition-colors">{title}</a>
  </h3>
  <p class="text-sm text-gray-500 mb-1">📍 {address}</p>
  {developer && <p class="text-sm text-gray-500 mb-2">Developer: {developer}</p>}
  <p class="text-gray-600 text-sm leading-relaxed mb-3">{summary}</p>
  {tags.length > 0 && (
    <div class="flex flex-wrap gap-2 mb-3">
      {tags.map((tag) => (
        <span class="text-xs bg-gray-50 text-gray-600 px-2 py-0.5 rounded-full border">{tag}</span>
      ))}
    </div>
  )}
  <div class="flex flex-col gap-2 mt-3 pt-3 border-t border-gray-50 sm:flex-row sm:items-center sm:justify-between">
    <span class="text-xs text-gray-400">Updated {lastUpdated.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
    <div class="flex flex-wrap items-center gap-x-4 gap-y-2">
      <a href={projectHref} class="text-accent hover:text-amber-700 text-xs font-medium transition-colors">Project details →</a>
      {cityPlanningUrl && (
        <a href={cityPlanningUrl} target="_blank" rel="noopener noreferrer" class="text-accent hover:text-amber-700 text-xs font-medium transition-colors">
          City Planning Docs →
        </a>
      )}
    </div>
  </div>
</article>
