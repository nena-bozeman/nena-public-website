---
import HeroCarousel from './HeroCarousel.astro';
---

<section class="relative min-h-[70vh] bg-primary text-white py-24 px-4 overflow-hidden flex items-center">
  <HeroCarousel />
  <div class="relative z-30 max-w-5xl mx-auto text-center w-full">
    <p class="text-accent font-semibold uppercase tracking-widest text-sm mb-4">Bozeman, Montana</p>
    <h1 class="font-serif text-5xl md:text-7xl font-bold mb-6 leading-tight">
      Northeast Neighborhood
    </h1>
    <p class="text-2xl md:text-3xl font-serif text-green-200 italic mb-8">
      "Last Best Neighborhood"
    </p>
    <p class="max-w-2xl mx-auto text-green-100 text-lg mb-10">
      A vibrant, historic community in the heart of Bozeman. Neighbors connecting, collaborating, and celebrating everything that makes our corner of Montana special.
    </p>
    <div class="flex flex-wrap gap-4 justify-center">
      <a href={`${import.meta.env.BASE_URL}events`} class="bg-accent hover:bg-amber-600 text-white font-semibold px-8 py-3 rounded-lg transition-colors">
        Upcoming Events
      </a>
      <a href={`${import.meta.env.BASE_URL}about`} class="border-2 border-green-300 hover:bg-green-800 text-white font-semibold px-8 py-3 rounded-lg transition-colors">
        About NENA
      </a>
    </div>
  </div>
</section>
