---
import NewsTagFilters from './NewsTagFilters.astro';
import type { Topic } from '../../schemas/topics';

export interface Props {
  filterTopics: Topic[];
  activeTopic?: Topic | null;
  title?: string;
}

const base = import.meta.env.BASE_URL;
const { filterTopics, activeTopic = null, title = 'Neighborhood News' } = Astro.props;
---

<div class="max-w-4xl mx-auto px-4 py-12">
  <h1 class="font-serif text-4xl font-bold text-primary mb-6">{title}</h1>
  <aside
    class="bg-cream rounded-lg border border-amber-100 p-5 mb-8 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4"
  >
    <p class="text-gray-700 text-sm sm:text-base">
      Get meeting recaps and neighborhood updates by email.
    </p>
    <a
      href={`${base}newsletter`}
      class="shrink-0 inline-flex justify-center bg-accent hover:bg-amber-600 text-white font-semibold text-sm px-5 py-2.5 rounded-lg transition-colors"
    >
      Newsletter signup
    </a>
  </aside>
  <NewsTagFilters topics={filterTopics} activeTopic={activeTopic} />
  <slot />
</div>
