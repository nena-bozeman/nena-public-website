---
import { formatTopicLabel, topicListingHref, type Topic } from '../../schemas/topics';

export interface Props {
  topics: Topic[];
  activeTopic?: Topic | null;
}

const base = import.meta.env.BASE_URL;
const { topics, activeTopic = null } = Astro.props;

const pill =
  'inline-flex items-center rounded-full border px-3 py-1 text-sm font-medium transition-colors';
const idle = 'border-amber-200 bg-white text-primary hover:bg-cream hover:border-accent';
const selected = 'border-accent bg-accent text-white shadow-xs';
---

<nav aria-label="Filter news by topic" class="mb-8 flex flex-wrap items-center gap-2">
  <span class="text-sm text-gray-600 w-full sm:w-auto sm:mr-1">Topics</span>
  <a
    href={`${base}news`}
    class:list={[pill, activeTopic === null ? selected : idle]}
    aria-current={activeTopic === null ? 'page' : undefined}
  >
    All
  </a>
  {
    topics.map((topic) => (
      <a
        href={topicListingHref(topic, base)}
        class:list={[pill, activeTopic === topic ? selected : idle]}
        aria-current={activeTopic === topic ? 'page' : undefined}
      >
        {formatTopicLabel(topic)}
      </a>
    ))
  }
</nav>
