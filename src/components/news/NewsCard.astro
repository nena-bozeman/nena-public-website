---
export interface Props {
  title: string;
  date: Date;
  summary: string;
  author?: string;
  tags?: string[];
  slug: string;
}

const base = import.meta.env.BASE_URL;
const { title, date, summary, author, tags = [], slug } = Astro.props;
const postHref = `${base}news/${slug}`;
---

<article class="bg-white rounded-lg shadow-sm hover:shadow-md transition-shadow border border-gray-100 p-6">
  <div class="flex items-center gap-3 mb-3">
    <time class="text-xs font-medium text-accent uppercase tracking-wide">
      {date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
    </time>
    {author && <span class="text-xs text-gray-400">by {author}</span>}
  </div>
  <h2 class="font-serif font-bold text-primary text-xl mb-2">
    <a href={postHref} class="hover:text-accent transition-colors">{title}</a>
  </h2>
  <p class="text-gray-600 text-sm leading-relaxed mb-4">{summary}</p>
  {tags.length > 0 && (
    <div class="flex flex-wrap gap-2 mb-4">
      {tags.map((tag) => (
        <span class="text-xs bg-amber-50 text-amber-700 px-2 py-0.5 rounded-full">{tag}</span>
      ))}
    </div>
  )}
  <a href={postHref} class="text-accent hover:text-amber-700 text-sm font-medium transition-colors">Read more →</a>
</article>
