---
interface Props {
  /** When true and the site runs in dev, shows a red DRAFT label. */
  show: boolean;
}

const { show } = Astro.props;
---

{
  show && import.meta.env.DEV && (
    <span
      class="inline-flex items-center rounded px-2 py-0.5 text-xs font-bold uppercase tracking-wide bg-red-600 text-white shrink-0"
      aria-label="Draft post"
    >
      DRAFT
    </span>
  )
}
