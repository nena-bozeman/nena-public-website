---
import { eventsListingHref } from '../../utils/events';

export interface Props {
  currentPage: number;
  totalPages: number;
}

const base = import.meta.env.BASE_URL;
const { currentPage, totalPages } = Astro.props;

const show = totalPages > 1;
---

{show && (
  <nav
    class="mt-10 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 border-t border-amber-100 pt-8"
    aria-label="Past events pagination"
  >
    <div class="text-sm text-gray-600 order-2 sm:order-1">
      Page <span class="font-medium text-gray-800">{currentPage}</span> of{' '}
      <span class="font-medium text-gray-800">{totalPages}</span>
    </div>
    <div class="flex items-center justify-center sm:justify-end gap-3 order-1 sm:order-2">
      {currentPage > 1 ? (
        <a
          href={eventsListingHref(currentPage - 1, base)}
          class="inline-flex items-center justify-center min-w-[7rem] px-4 py-2 rounded-lg border border-amber-200 bg-white text-sm font-medium text-primary hover:bg-cream hover:border-accent transition-colors"
        >
          ← Previous
        </a>
      ) : (
        <span
          class="inline-flex items-center justify-center min-w-[7rem] px-4 py-2 rounded-lg border border-gray-100 bg-gray-50 text-sm text-gray-400 cursor-not-allowed"
          aria-disabled="true"
        >
          ← Previous
        </span>
      )}
      {currentPage < totalPages ? (
        <a
          href={eventsListingHref(currentPage + 1, base)}
          class="inline-flex items-center justify-center min-w-[7rem] px-4 py-2 rounded-lg bg-accent hover:bg-amber-600 text-white text-sm font-medium transition-colors"
        >
          Next →
        </a>
      ) : (
        <span
          class="inline-flex items-center justify-center min-w-[7rem] px-4 py-2 rounded-lg border border-gray-100 bg-gray-50 text-sm text-gray-400 cursor-not-allowed"
          aria-disabled="true"
        >
          Next →
        </span>
      )}
    </div>
  </nav>
)}
