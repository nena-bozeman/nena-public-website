---
import type { CollectionEntry } from 'astro:content';

export interface Props {
  entries: CollectionEntry<'history'>[];
}

const { entries } = Astro.props;
const sorted = entries.sort((a, b) => a.data.year - b.data.year);

const byDecade = sorted.reduce((acc, entry) => {
  const dec = entry.data.decade;
  if (!acc[dec]) acc[dec] = [];
  acc[dec].push(entry);
  return acc;
}, {} as Record<number, CollectionEntry<'history'>[]>);

const categoryColors: Record<string, string> = {
  founding: 'bg-amber-100 text-amber-800',
  development: 'bg-blue-100 text-blue-800',
  community: 'bg-green-100 text-green-800',
  landmark: 'bg-purple-100 text-purple-800',
  other: 'bg-gray-100 text-gray-800',
};
---

<div class="space-y-12">
  {Object.entries(byDecade).map(([decade, decadeEntries]) => (
    <div>
      <h2 class="font-serif text-3xl font-bold text-primary mb-6 pb-2 border-b-2 border-accent">{decade}s</h2>
      <div class="relative">
        <div class="absolute left-6 top-0 bottom-0 w-0.5 bg-amber-200"></div>
        <div class="space-y-8">
          {decadeEntries.map((entry) => (
            <div class="relative pl-16">
              <div class="absolute left-0 top-1 w-12 h-12 bg-primary text-white rounded-full flex items-center justify-center text-sm font-bold font-serif">
                {entry.data.year}
              </div>
              <div class="bg-white rounded-lg shadow-sm border border-gray-100 p-5">
                <div class="flex items-center gap-2 mb-2">
                  <span class={`text-xs font-medium px-2 py-0.5 rounded-full ${categoryColors[entry.data.category] ?? 'bg-gray-100 text-gray-800'}`}>
                    {entry.data.category.charAt(0).toUpperCase() + entry.data.category.slice(1)}
                  </span>
                </div>
                <h3 class="font-serif font-bold text-primary text-lg">{entry.data.title}</h3>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  ))}
</div>
